# ============================================================
# PFLICHTFELDER
# ============================================================

# Google Places API Key
# Erstelle einen Key unter: https://console.cloud.google.com/apis/credentials
# Aktiviere die "Places API" (New) unter APIs & Services > Library
GOOGLE_API_KEY=dein_google_api_key_hier

# ============================================================
# SCRAPING-LIMITS (optional, Defaults siehe unten)
# ============================================================

# Max. WA-Leads pro Run (Default: 200)
# 200/Woche = ~800/Monat -> passt unter Instantly Growth Limit (1000/Monat)
MAX_LEADS_PER_RUN=200

# Max. Leads pro Kategorie ueber alle Staedte (Default: 13)
# Formel: MAX_LEADS_PER_RUN / Anzahl Kategorien (aktuell 15)
MAX_LEADS_PER_CATEGORY=13

# Max. Leads pro Stadt+Kategorie-Kombination (Default: 35)
# Verhindert dass eine einzelne Grossstadt eine Kategorie dominiert
MAX_LEADS_PER_COMBO=35

# ============================================================
# INSTANTLY.AI (optional)
# ============================================================

# API Key aus dem Instantly Dashboard: Settings > Integrations > API
INSTANTLY_API_KEY=dein_instantly_api_key

# Campaign-Mapping als JSON: category_key -> Campaign ID
# Kategorien ohne Eintrag werden uebersprungen
INSTANTLY_CAMPAIGNS={"friseur":"CAMPAIGN_ID","kosmetik":"CAMPAIGN_ID","piercing":"CAMPAIGN_ID","tattoo":"CAMPAIGN_ID","personal_trainer":"CAMPAIGN_ID","massage":"CAMPAIGN_ID","physiotherapie":"CAMPAIGN_ID","heilpraktiker":"CAMPAIGN_ID","yoga":"CAMPAIGN_ID","osteopathie":"CAMPAIGN_ID","fotograf":"CAMPAIGN_ID","fahrschule":"CAMPAIGN_ID","nachhilfe":"CAMPAIGN_ID","coaching":"CAMPAIGN_ID","ernaehrungsberatung":"CAMPAIGN_ID"}
