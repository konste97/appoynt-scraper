# Google Places API Key
# Erstelle einen Key unter: https://console.cloud.google.com/apis/credentials
# Aktiviere die "Places API" (New) unter APIs & Services > Library
GOOGLE_API_KEY=dein_google_api_key_hier

# Slack-Benachrichtigung (optional)
# Bot erstellen: https://api.slack.com/apps → Create New App → Bot Token Scopes: chat:write, files:write
SLACK_BOT_TOKEN=xoxb-dein-bot-token
SLACK_CHANNEL_ID=C08XXXXXXXX
